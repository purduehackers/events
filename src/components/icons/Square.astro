---
interface Props {
  class?: string;
  strokeWidth?: number;
  [key: string]: unknown;
}
const { class: className, strokeWidth = 2, ...rest } = Astro.props;
---

<svg 
    viewBox="0 0 24 24" 
    fill="none" 
    xmlns="http://www.w3.org/2000/svg"
    class={className}
    {...rest}
>
    <path fill={strokeWidth > 0 ? "none" : "currentColor"} 
            stroke={strokeWidth > 0 ? "currentColor" : "none"} 
            stroke-width={strokeWidth} 
            d="M4.5 4.5 h15v15h-15z"/>
</svg>