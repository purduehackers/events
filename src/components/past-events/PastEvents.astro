---
import PastEventsClient from "./PastEventsClient.tsx";

const INITIAL_LIMIT = 30;
const apiUrl = new URL('/api/events', Astro.url).href;
---

<div
  id="past-events"
  class="lg:container flex flex-col mb-14 pt-6 sm:pt-14 px-4 sm:px-12 md:px-18 xl:px-28 text-left gap-y-4 lg:max-w-screen-2xl mx-auto"
>
  <div class="flex flex-wrap items-end justify-between gap-4">
    <h2 class="text-3xl sm:text-3xl font-mono font-black m-0">Past events</h2>
  </div>

  <PastEventsClient
    client:load
    limit={INITIAL_LIMIT}
    apiUrl={apiUrl}
  />
</div>
