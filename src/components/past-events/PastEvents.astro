---
import type { EventType, SemesterType } from "@/types";
import { CMS_URL } from "@/utilities/constants";
import { getSemestersNewestFirst } from "@/utilities/helpers";

import PastEventsClient from "./PastEventsClient.tsx";

const INITIAL_PAGE = 1;
const INITIAL_LIMIT = 2;

const initialSemesters: SemesterType[] = getSemestersNewestFirst();

// Build search params to query cms events
const params = new URLSearchParams();
params.set("sort", "-start");
params.set("where[start][less_than]", new Date().toISOString());
params.set("limit", String(INITIAL_LIMIT));
params.set("page", String(INITIAL_PAGE));

// Fetch initial page of past events to render on the server
const res = await fetch(`${CMS_URL}/api/events?${params.toString()}`);
const data = (await res.json()) as { docs: EventType[]; hasNextPage: boolean };
const initialEvents = data.docs ?? [];
const initialHasNextPage = Boolean(data.hasNextPage);
---

<div
  id="past-events"
  class="lg:container flex flex-col mb-14 sm:pt-14 px-4 sm:px-12 md:px-18 xl:px-28 text-left gap-y-4 lg:max-w-screen-2xl mx-auto"
>
  <div class="flex flex-wrap items-end justify-between gap-4">
    <h2 class="text-3xl sm:text-4xl font-mono font-black m-0">Past events</h2>
  </div>

  <PastEventsClient
    client:load
    initialEvents={initialEvents}
    initialSemesters={initialSemesters}
    initialPage={INITIAL_PAGE}
    limit={INITIAL_LIMIT}
    initialHasNextPage={initialHasNextPage}
  />
</div>

<script>
  import "../../scripts/scrollAnim";
</script>
