---
import PixelGraphic from "./PixelGraphic.astro";
import angryManImage from "../assets/graphics/angry_man.png";
import fishLegsImage from "../assets/graphics/fish_with_legs.png";
import lizardGunImage from "../assets/graphics/lizard_gun.png";
import angryDudeSpriteSheet from "../assets/sprites/angry_dude_sprite.png";

import Sprite from "./Sprite.astro";
---

<div
  class="bg-grid-animated sticky top-0 z-0 w-full px-5 py-14 flex flex-col items-start justify-top mt-0 grow-0 flex-1"
  style="--grid-size: 26px;"
>
  <div class="mt-8 sm:mt-16">
    <h1
      class="text-4xl sm:text-5xl lg:text-6xl uppercase font-pixel dark:text-amber-500"
    >
      Purdue Hackers 
      <span class="text-amber-500 dark:text-yellow">Events</span>
    </h1>
    <p class="mt-12 text-lg sm:text-[15px] font-subtext font-normal">
      <span class="font-display">{'> '}</span>
      Check out &amp; sign up for upcoming events from <span
        ><a
          href="https://purduehackers.com"
          target="_blank"
          class="font-bold"
          >Purdue Hackers</a
        ></span
      >.
    </p>
  </div>
  <div >
    <PixelGraphic
      class="hidden absolute top-40 -left-10 rotate-50 opacity-70"
      src={fishLegsImage.src}
      size={270}
    />
    <PixelGraphic
      class="hidden absolute top-6 left-0 opacity-70"
      src={lizardGunImage.src}
      size={340}
    />
    <PixelGraphic
      class="hidden absolute top-6 -right-20 opacity-85 dark:invert"
      src={angryManImage.src}
      size={340}
    />
    <!-- Animated creatura -->
    <Sprite
      id="angry-guy-sprite"
      className="absolute top-15 right-12 opacity-85 scale-180 dark:invert"
      backgroundImage={angryDudeSpriteSheet.src}
      spriteSize={224}
      numRows={1}
      numCols={2}
      numFrames={2}
      duration={1.5}
    />
  </div>
</div>
