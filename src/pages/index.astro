---
export const prerender = false;

import CurrentEvents from "../components/CurrentEvents.tsx";
import PastEvents from "../components/past-events/PastEvents.tsx";
import Layout from "@/layouts/Layout.astro";
import HomeLayout from "@/layouts/HomeLayout.astro";
import Clock from "@components/Clock";

const INITIAL_LIMIT = 30;
const apiUrl = new URL('/api/events', Astro.url).href;
---

<Layout>
  <HomeLayout>
    <div class="flex justify-center">
      <div class="lg:max-w-screen-2xl px-4 sm:px-12 md:px-18 xl:px-20">
        <div class=" pr-8">
          <div class="font-mono text-gray-500 dark:text-gray-400 text-xs sm:text-sm flex flex-col md:flex-row justify-between gap-2 mb-0 pt-6 sm:pt-14 text-left mx-auto">
            <div>* All event times are listed in Eastern Time (America/Indianapolis).</div>
            <div>Local - <Clock client:load /></div>
          </div>
          <div
            class="flex flex-col pt-6 sm:pt-14 text-left gap-y-4 mx-auto"
          >
            <h2 class="sm:mb-4 text-3xl sm:text-3xl font-mono font-black m-0">Upcoming</h2>
            <CurrentEvents client:load apiUrl={apiUrl} />
          </div>
          <div
            id="past-events"
            class="flex flex-col mb-14 pt-6 sm:pt-14 text-left gap-y-4 mx-auto"
          >
            <div class="flex flex-wrap items-end justify-between gap-4">
              <h2 class="text-3xl sm:text-3xl font-mono font-black m-0">Past events</h2>
            </div>

            <PastEvents
              client:load
              limit={INITIAL_LIMIT}
              apiUrl={apiUrl}
            />
          </div>
        </div>
        <div class="hidden w-1/3">
          calendar integration
        </div>
      </div>
    </div>
  </HomeLayout>
</Layout>
