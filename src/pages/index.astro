---
export const prerender = false;

import CurrentEvents from "../components/CurrentEvents.astro";
import PastEventsClient from "../components/past-events/PastEventsClient.tsx";
import Layout from "@/layouts/Layout.astro";
import HomeLayout from "@/layouts/HomeLayout.astro";
import Clock from "@components/Clock";
---

<Layout>
  <HomeLayout>
    <div class="font-mono text-gray-500 dark:text-gray-400 text-xs sm:text-sm flex flex-col md:flex-row justify-between gap-2 lg:container mb-0 pt-6 sm:pt-14 px-4 sm:px-12 md:px-18 xl:px-28 text-left lg:max-w-screen-2xl mx-auto">
      <div>* All event times are listed in Eastern Time (America/Indianapolis).</div>
      <div>Local - <Clock client:load /></div>
    </div>
    <div class="flex">
      <div class=" pr-8">
        <CurrentEvents />
        <div
          id="past-events"
          class="lg:container flex flex-col mb-14 pt-6 sm:pt-14 px-4 sm:px-12 md:px-18 xl:px-28 text-left gap-y-4 lg:max-w-screen-2xl mx-auto"
        >
          <div class="flex flex-wrap items-end justify-between gap-4">
            <h2 class="text-3xl sm:text-3xl font-mono font-black m-0">Past events</h2>
          </div>

          <PastEventsClient client:load limit={30} apiUrl="/api/events" />
        </div>
      </div>
      <div class="hidden w-1/3">
        calendar integration
      </div>
    </div>
  </HomeLayout>
</Layout>
