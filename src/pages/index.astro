---
import CurrentEvents from "../components/CurrentEvents.astro";

import Hero from "../components/Hero.astro";
import Marquee from "@/components/Marquee.astro";
import SemesterFilter from "../components/past-events/SemesterFilter.tsx";
import CategoryFilter from "@/components/past-events/CategoryFilter";

import PastEvents from "../components/past-events/PastEvents.astro";
import Layout from "../layouts/Layout.astro";

import { EVENT_CATEGORIES } from "@/types";
import {
  getSemestersNewestFirst,
} from "@/utilities/helpers";

const allSemesters = getSemestersNewestFirst();
console.log("allSems: ", allSemesters)

const categories = [...EVENT_CATEGORIES, "other"];
---

<Layout>
  <Hero />
  <div id="hero-sentinel" class="relative -top-16 h-0 w-full pointer-events-none" aria-hidden="true" />
  <Marquee 
    class="hidden text-pink-500 bg-amber-300" 
    text="HACK."
  />
  <Marquee 
    class="sticky top-0 text-sm text-white dark:text-white bg-neutral-800 dark:bg-purple-700 group-hover/marquee:bg-amber-400 py-1" 
    text="HACK"
  />
  <div class="z-10 bg-body-light dark:bg-body-dark">
    <div class="z-60 sticky top-8 p-4 flex items-center gap-2 bg-zinc-200 dark:bg-zinc-700 text-[15px] font-pixel uppercase">
      <h4>Filter by:</h4>
      <SemesterFilter client:load semesters={allSemesters} />
      <CategoryFilter client:load categories={categories} />
    </div>

    <CurrentEvents />

    <PastEvents semesters={allSemesters.splice(0, 2)} />
  </div>
</Layout>
