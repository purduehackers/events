---
import Hero from "../components/Hero.astro";
import Marquee from "@/components/Marquee.astro";
import SemesterFilter from "../components/past-events/SemesterFilter.tsx";

import PastEvents from "../components/past-events/PastEvents.astro";
import Layout from "../layouts/Layout.astro";

import {
  getSemestersNewestFirst,
} from "@/utilities/helpers";

export async function getStaticPaths() {
    // Get all valid semesters for path generation
    const allSemesters = getSemestersNewestFirst(); //.filter((sem) => getEventsInSemester(allEvents, sem).length > 0);

    return allSemesters.map((semester) => {
        return {
        params: { 
            semester: `${semester.season}-${semester.year}`
        },
        props: {
            allSemesters: allSemesters,
            semester,
        },
        };
    });
}
const { allSemesters, semester } = Astro.props;
---

<Layout>
  <Hero />
  <div id="hero-sentinel" class="relative -top-16 h-0 w-full pointer-events-none" aria-hidden="true" />
  <Marquee 
    class="hidden text-pink-500 bg-amber-300" 
    text="HACK."
  />
  <Marquee 
    class="sticky top-0 text-sm text-white dark:text-white bg-neutral-800 dark:bg-purple-700 group-hover/marquee:bg-amber-400 py-1" 
    text="HACK"
  />
  <div class="z-10 bg-body-light dark:bg-body-dark">
    <div class="flex items-center gap-2 text-[15px] font-pixel uppercase">
      <h4>Filter by:</h4>
      <SemesterFilter client:load semesters={allSemesters} />
    </div>

    <PastEvents semesters={[semester]} />
  </div>
</Layout>
