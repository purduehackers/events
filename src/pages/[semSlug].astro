---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import HomeLayout from "@/layouts/HomeLayout.astro";
import SemesterEvents from "@/components/SemesterEvents";

import {
  getSemesterDateRange
} from "@/utilities/helpers";
import type { EventType, SemesterType, PayloadResponse } from "@/types";

// Process semester dynamically and validate params
const { semSlug } = Astro.params; // e.g. "fall-2024"
const parts = semSlug?.split("-");
if (!parts || parts.length !== 2) {
    return Astro.redirect('/404');
}

const seasonRaw = parts[0]?.toLowerCase();
const yearNum = Number(parts[1]);
const validSeasons = ["spring", "summer", "fall"];
if (!seasonRaw || !validSeasons.includes(seasonRaw) || !Number.isInteger(yearNum) || Number.isNaN(yearNum)) {
    return Astro.redirect('/404');
}

const semester: SemesterType = { year: yearNum, season: seasonRaw as SemesterType["season"] };

// Get semester date range
const { start, end } = getSemesterDateRange(semester);

// Fetch events in given semester
const params = new URLSearchParams();
params.set("sort", "-start");
params.set("where[start][greater_than]", start.toISOString());
params.set("where[start][less_than]", end < new Date() ? end.toISOString() : new Date().toISOString()); // only show past events
params.set("limit", "100");

const apiUrl = new URL('/api/events', Astro.url);
const res = await fetch(`${apiUrl}?${params.toString()}`);
const data: PayloadResponse<EventType> = await res.json();
const events: EventType[] = data.docs;
---

<Layout>
    <HomeLayout>
        <div
            id="past-events"
            class="lg:container flex flex-col mb-14 sm:pt-14 px-4 sm:px-12 md:px-18 xl:px-28 text-left gap-y-4 lg:max-w-screen-2xl mx-auto"
        >
            <div class="flex flex-wrap items-end justify-between gap-4">
                 <h3 class="hidden text-base sm:text-2xl font-normal leading-none p-0 m-0 uppercase font-pixel">
                    {semester.season} {semester.year}
                </h3>
            </div>

            <SemesterEvents client:load initialEvents={events} semester={semester} />
        </div>
    </HomeLayout>
</Layout>