---
export const prerender = false;

import { format } from "date-fns";
import { getLocalizedEventTimes } from "@/utilities/helpers";

import Layout from "@/layouts/Layout.astro";
import Stat from "@/components/past-events/Stat.astro";
import Image from "@/components/Image";
import MapPin from "@/assets/map-pin.svg";
import Gallery from "@/components/past-events/Gallery.astro";
import Description from "@/components/past-events/Description.astro";
import Rsvp from "@/components/Rsvp";

import type { EventType, PayloadResponse } from "@/types";
import { CMS_URL } from "@/utilities/constants";
import type { SerializedEditorState } from '@payloadcms/richtext-lexical/lexical';
import { convertLexicalToHTMLAsync } from '@payloadcms/richtext-lexical/html-async';

let { cat, slug } = Astro.params;

// Fetch event dynamically from CMS
if (cat == "workshops") cat = "workshop";
if (cat == "callouts") cat = "callout";
let res = await fetch(`${CMS_URL}/api/events?where[eventType][contains]=${cat?.toLowerCase()}&where[slug][equals]=${slug}`, {
  headers: {
    Authorization: `service-accounts API-Key ${import.meta.env.PAYLOAD_API_KEY}`,
  },
});
const data: PayloadResponse<EventType> = await res.json();
const event = data.docs[0];
if (!event) {
  // No matching event found
  return Astro.redirect('/404');
}

// Convert rich text once during build
const descriptionHTML = await convertLexicalToHTMLAsync({
  data: event.description as SerializedEditorState,
});

const isUpcoming = new Date(event.start) > new Date();
const image = event.images?.[0]?.image?.thumbnailURL ?? event.images?.[0]?.image?.url ?? null;

const {
    localizedStart,
    localizedStartTime,
    localizedEndTime,
} = getLocalizedEventTimes(event);
---
<Layout>
  <div
    class="min-h-screen overflow-hidden flex flex-col font-name"
  >
    {/* Event header */}
    <div
      class="flex flex-row gap-8 grow-0 items-center justify-center w-full flex-1 px-5 pt-20 sm:pt-28 pb-8 sm:pb-16 text-center sm:px-20"
    >
      <Image client:load
        src={image}
        alt={`${event.name} thumbnail`}
        className="w-40 h-40 rounded-lg"
      />
      <div class="flex flex-col gap-4">
        <h1 class="text-black dark:text-yellow font-pixel uppercase text-4xl sm:text-5xl lg:text-5xl font-normal">
          {event.name}
        </h1>
        <div class="text-base md:text-lg 2xl:text-2xl font-subtext font-normal">
          <div class="flex flex-col gap-2 items-start justify-center">
            <div class="flex gap-4 items-center justify-center">
              <div class="w-10 h-10 border-2 border-black font-pixel uppercase text-black dark:text-yellow dark:border-yellow flex flex-col items-center justify-center">
                <div class="w-full py-0.5 text-xs leading-none bg-black dark:bg-yellow text-white dark:text-black">{format(localizedStart, "MMM")}</div>
                <div class="grow text-xl leading-none flex items-center justify-center">{format(localizedStart, "d")}</div>
              </div>
              <div class="flex flex-col gap-0 items-start justify-center dark:text-gray-200">
                <div class="font-semibold">
                  {format(localizedStart, "EEEE, MMMM do, yyyy")} 
                </div>
                <div class="text-base">
                  {localizedStartTime} — {localizedEndTime} ET
                </div>
              </div>
            </div>
            {
              event.location_name && (
                <div class="flex gap-4 items-center justify-center font-bold dark:text-gray-200">
                  <div class="w-10 h-10 border-2 border-black font-pixel uppercase text-black dark:text-yellow dark:border-yellow flex flex-col items-center justify-center">
                    <MapPin class="w-5" />
                  </div>
                  <div>
                    {event.location_url ? (
                      <a
                        href={event.location_url}
                        target="_blank"
                        class="font-semibold hover:text-purple-500 dark:hover:text-yellow"
                      >
                        {event.location_name}
                      </a>
                    ) : (
                      <>{event.location_name}</>
                    )}
                  </div>
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>

    {/* Event description body */}
    <div class="flex flex-col items-center justify-center py-12 sm:px-20 mb-auto border-t-2 border-b-2 bg-body-light dark:bg-body-dark bg-grid [--grid-size:100px] [--grid-color:rgba(0,0,0,0.5)] dark:[--grid-color:rgba(255,255,255,0.5)]">
      <div class="flex flex-col sm:flex-row-reverse sm:items-start sm:gap-x-4 items-center">
        {
            event.stats && event.stats.length > 0 && (
                <div class="bg-white dark:bg-black text-black dark:text-white border-2 border-black dark:border-amber-400 flex flex-row flex-1 items-center justify-center gap-4 sm:gap-8 mx-4 sm:mx-0 max-w-fit sm:max-w-min max-h-fit p-6 sm:p-8 text-center sm:flex-col">
                {event.stats.map((stat) => (
                    <Stat data={stat.data} label={stat.label} />
                ))}
                </div>
            )
        }

        <div class="w-full sm:min-w-100 sm:max-w-lg md:max-w-xl">
          <div class="flex flex-col justify-items-center sm:justify-items-end">
            <div class="bg-zinc-900 dark:bg-(--gray-900) dark:border-1 dark:border-zinc-700 text-white border-2 p-4 sm:p-6 mx-4 mt-4 sm:mx-0 sm:mt-0 mb-4">
              <p class="text-yellow dark:text-purple-700 font-display uppercase text-sm mb-4">--details--</p>
              <Description>
                <div set:html={descriptionHTML} />
              </Description>
            </div>

            {isUpcoming && <Rsvp client:load eventId={event.id} />}

            {event.images && event.images.length > 0 && (
              <Gallery
                images={event.images.map((img) => ({
                  url: img.image.url,
                  alt: img.image?.alt ?? event.name,
                }))}
              />
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
