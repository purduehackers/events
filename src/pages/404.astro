---
import Layout from "@/layouts/Layout.astro";
---
<Layout>
  <div
    class="min-h-screen overflow-hidden flex flex-col font-name"
  >
    {/* Event header */}
    <div
      class=" bg-body-light dark:bg-body-dark flex flex-col grow-0 items-center justify-top w-full flex-1 px-5 pt-20 sm:pt-28 pb-8 sm:pb-16 text-center sm:px-20"
    >
      <h1 class="text-black dark:text-amber-500 font-pixel uppercase text-4xl sm:text-5xl lg:text-6xl font-normal">
        Oops! 
      </h1>
      <div class="mt-4 text-base md:text-lg 2xl:text-2xl font-subtext font-normal">
        <p class="mt-3 flex flex-row gap-x-2 items-center justify-center dark:text-gray-200">
          This page disappeared into the woods.
        </p>
      </div>
    </div>

    {/* Event description body */}
    <div class="flex flex-col items-center justify-center py-12 sm:px-20 mb-auto border-t-2 border-b-2 bg-grid [--grid-size:100px] [--grid-color:rgba(0,0,0,0.5)] dark:[--grid-color:rgba(255,255,255,0.5)]">
      <div class="flex flex-col sm:flex-row-reverse sm:items-start sm:gap-x-4 items-center">
        <div class="w-full sm:min-w-100 sm:max-w-lg md:max-w-xl">
          <div class="flex flex-col justify-items-center sm:justify-items-end">
            <div class="bg-zinc-900 dark:bg-gray-300 rounded-sm text-white dark:text-black border-2 p-4 sm:p-6 mx-4 mt-4 sm:mx-0 sm:mt-0 mb-4">
              <p class="text-yellow dark:text-purple-700 font-display uppercase text-sm mb-4">--details--</p>
              This page is not found, just like your dad.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
