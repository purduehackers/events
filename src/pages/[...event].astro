---
import { getCollection, render } from "astro:content";
import { format } from "date-fns";

import Layout from "@/layouts/Layout.astro";
import { getEventMetadata, getEventSlug } from "@/utilities/helpers";

import Clock from "@/assets/clock.svg";
import Stat from "@/components/past-events/Stat.astro";
import MapPin from "@/assets/map-pin.svg";

import Gallery from "@/components/past-events/Gallery.astro";
import Description from "@/components/past-events/Description.astro";
import DiscordCard from "@/components/past-events/DiscordCard.astro";

export async function getStaticPaths() {
  const events = await getCollection("events");

  return events.map((event) => {
    let slug = getEventSlug(event.filePath ?? "");
    return {
      params: {
        event: slug,
      },
      props: {
        event,
      },
    };
  });
}

const { event } = Astro.props;
const { Content } = await render(event);

const { name, localizedStart, localizedStartTime, localizedEndTime } =
  getEventMetadata(event);
---

<Layout>
  <div
    class="min-h-screen overflow-hidden flex flex-col font-title"
  >
    {/* Event header */}
    <div
      class=" bg-body-light dark:bg-body-dark flex flex-col grow-0 items-center justify-top w-full flex-1 px-5 pt-20 sm:pt-28 pb-8 sm:pb-16 text-center sm:px-20"
    >
      <h1 class="text-black dark:text-amber-500 font-pixel uppercase text-4xl sm:text-5xl lg:text-6xl font-normal">
        {name}
      </h1>
      <div class="mt-4 text-base md:text-lg 2xl:text-2xl font-subtext font-normal">
        <p class="mt-3 flex flex-row gap-x-2 items-center justify-center dark:text-gray-200">
          <Clock class="w-5" />
          {format(localizedStart, "MMM do, yyyy")} • {
            localizedStartTime
          }—{localizedEndTime}
        </p>
        {
          event.data.location_name && (
            <p class="mt-1 flex flex-row gap-x-2 items-center justify-center font-bold dark:text-gray-200">
              <MapPin class="w-5" />
              <span>
                {event.data.location_url ? (
                  <a
                    href={event.data.location_url}
                    target="_blank"
                    class="hover:text-amber-500"
                  >
                    {event.data.location_name}
                  </a>
                ) : (
                  <>{event.data.location_name}</>
                )}
              </span>
            </p>
          )
        }
      </div>
    </div>

    {/* Event description body */}
    <div class="flex flex-col items-center justify-center py-12 sm:px-20 mb-auto border-t-2 border-b-2 bg-grid [--grid-size:100px] [--grid-color:rgba(0,0,0,0.5)] dark:[--grid-color:rgba(255,255,255,0.5)]">
      <div class="flex flex-col sm:flex-row-reverse sm:items-start sm:gap-x-4 items-center">
        {
          event.data.stats && event.data.stats.length > 0 && (
            <div class="bg-white dark:bg-black text-black dark:text-white border-2 border-black dark:border-amber-400 flex flex-row flex-1 items-center justify-center gap-4 sm:gap-8 mx-4 sm:mx-0 max-w-fit sm:max-w-min max-h-fit p-6 sm:p-8 text-center sm:flex-col">
              {event.data.stats.map((stat) => (
                <Stat data={stat.data} label={stat.label} />
              ))}
            </div>
          )
        }

        <div class="sm:max-w-lg md:max-w-xl">
          <div class="flex flex-col justify-items-center sm:justify-items-end">
            <div class="bg-zinc-900 dark:bg-gray-300 rounded-sm text-white dark:text-black border-2 p-4 sm:p-6 mx-4 mt-4 sm:mx-0 sm:mt-0 mb-4 sm:w-fit">
              <p class="text-yellow dark:text-purple-700 font-display uppercase text-sm mb-4">--details--</p>
              <Description><Content /></Description>
            </div>

            <Gallery event_classification={event.filePath?.split("/").slice(2)[1]!} event_version={event.filePath?.split("/").slice(2)[2]!} />
          </div>
        </div>
      </div>

      <div class="mt-16 mx-4 sm:mx-auto sm:max-w-md md:max-w-lg">
        <DiscordCard />
      </div>
    </div>
  </div>
</Layout>
