---
import "../styles/global.css";

// Import fonts
import "@fontsource-variable/inconsolata"; // Supports weights 200-900
import "@fontsource-variable/jetbrains-mono"; // Supports weights 100-800
import "@fontsource/silkscreen/400.css";
import "@fontsource/silkscreen/700.css";
import "@fontsource-variable/space-grotesk";
import "@fontsource/space-mono";

import Navbar from "../components/Navbar.tsx";
import Footer from "../components/Footer.astro";

import logoImg from "@/../public/glider.svg";
import { getImage } from "astro:assets";
import SocialMetaTags from "./components/SocialMetaTags.astro";

const appleTouchIcon = await getImage({
    src: logoImg,
    width: 180,
    height: 180,
    format: "png",
});
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg" href="/glider.svg" />
        <link rel="apple-touch-icon" href={appleTouchIcon.src} />
        <meta name="generator" content={Astro.generator} />
        <SocialMetaTags title={""} />
        <title>Events - Purdue Hackers</title>
        
        <script is:inline>
            // Apply theme synchronously before React hydration to prevent flash
            function getTheme() {
                const saved = typeof localStorage !== "undefined" ? localStorage.getItem("theme") : null;
                if (saved) return saved;
                return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            }
            
            function setTheme() {
                if (getTheme() === "light") {
                    document.documentElement.classList.remove("dark");
                } else {
                    document.documentElement.classList.add("dark");
                }
            }
            
            setTheme();
        </script>
    </head>
    <body>
        <main>
            <div class="min-h-screen flex flex-col font-title">
                <Navbar client:load />

                <slot />

                <Footer />
            </div>
        </main>
    </body>
</html>
